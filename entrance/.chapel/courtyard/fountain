#!/usr/bin/env bash
# Если вы это читаете, значит вы вышли за пределы игры
# и читаете код, который управляет игрой.
#
#                    Поздравляем!
#
# Изучение Linux — это прежде всего любопытство, так что
# читайте этот код и попробуйте понять, что он делает.
#
# Когда будете готовы продолжить игру, возвращайтесь
# к свиткам. Если застряли — создайте issue на Gitlab.
# Мы с радостью дадим подсказку.
#
damage() {
    cat << EOF
Вы пытаетесь сопротивляться, но не можете. Вы опускаете руку
в фонтан и чувствуете, как кожа обжигается. Боль выводит
вас из транса, и вы теряете лишь -2 HP.

Не забудьте вычесть 2 очка из переменной HP:

let "HP=HP-2"

EOF

}

CURSE=`find .. -type f -name ".curse"`

printf "Хотите подойти к фонтану? y/n  "
read RESP

if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
    cat << EOF
Воды сверкают в свете вашего взгляда. Вы чувствуете,
что вас тянет к ним.

EOF
    if [ x$CURSE = "x" ]; then
        cat << EOF
Но вдруг вы чувствуете силу отвернуться. Вы слышите
вздох от алтаря в часовне.

EOF
   else
       damage
   fi
else
    if [ ! -z "$CURSE" ]; then
	damage
    fi
fi

[ -f ../.curse ] && rm ../.curse
