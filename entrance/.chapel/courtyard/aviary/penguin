#import global functions from toplevel directory
FUNCTIONS=$(pwd)
FUNCTIONS=${FUNCTIONS%entrance*}entrance/.functions
. $FUNCTIONS

penguin_bite () {
    cat << EOF
Пингвин грызёт вашу Сумку Хранения в надежде на
кусочек. Ничего не найдя, он щиплет вас за руку, нанося 1
очко урона. (let "HP=HP-1"). Вы можете избежать этого урона,
если у вас есть меч и вы хотите атаковать пингвина.

EOF
printf "Хотите атаковать пингвина? y/n  "
	read RESP
	if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
        cat << EOF
Вы атакуете пингвина, быстро расправляясь с ним одним
быстрым ударом. Это привлекает внимание других пингвинов
в комнате. Они объединяются и бросаются на вас. Вы сражаетесь
изо всех сил.

EOF
        let HP=HP-5
        export HP
        if [ "$HP" -le 0 ]; then
            cat << EOF
Толпа пингвинов снижает ваши очки здоровья до нуля. Вы
погибли от нападения стаи.

EOF
            gameover
            exit 1
        else
            cat << EOF
Но толпа пингвинов не терпит угнетения, и вскоре
вы оказываетесь замурованы в ледяной глыбе. Вы остаётесь
идеально сохранённым 128 лет. Когда вас разморозят,
вы сможете продолжить приключение.

EOF
        fi
	else
        let HP=HP--
        export HP
	    echo "Вы сохраняете хладнокровие и не набрасываетесь на пингвина."
	fi
}

cat << EOF
Одна из птиц наконец замечает ваше присутствие. Она наклоняет
голову набок, словно маня вас подойти ближе.

EOF
printf "Подойдёте ближе? y/n  "
read RESP

if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
    cat << EOF
Вы делаете шаг вперёд, и птица бросается к вам, широко
раскрыв клюв.

EOF
    printf "У вас случайно есть рыба? y/n  "
    read RESP

    if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
        if grep  --quiet --only-matching fish <<< $I; then
            cat << EOF

Вы бросаете рыбу пингвину, который ловит её
на лету и проглатывает целиком.

Не забудьте убрать рыбу из инвентаря. Попробуйте
следующую команду:

export I=\$(sed "s/fish//; s/,,/,/" <<< \$I)

EOF
        else
            echo "У вас нет рыбы!"
            echo
            penguin_bite
        fi
   else
        penguin_bite
   fi
else
    cat << EOF
Вы осторожно отступаете от пингвина. Он теряет к вам
интерес и ковыляет прочь.

EOF

fi
