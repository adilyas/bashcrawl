#!/usr/bin/env bash
# Если вы это читаете, значит вы вышли за пределы игры
# и читаете код, который управляет игрой.
#
#                    Поздравляем!
#
# Изучение Linux — это прежде всего любопытство, так что
# читайте этот код и попробуйте понять, что он делает.
#
# Когда будете готовы продолжить игру, возвращайтесь
# к свиткам. Если застряли — создайте issue на Gitlab.
# Мы с радостью дадим подсказку.
#

ITEMS=("rags" "fish")

if ! grep --quiet "${ITEMS[0]}" <<< "$I" ; then
    cat << EOF
На полу куча старых **тряпок**. Они ветхие и изношенные
от времени, и, вероятно, остались от какого-то бедного
искателя приключений.

EOF
    printf "Хотите взять тряпки? y/n  "

    read RESP

    if [ "$RESP" = "y" -o "$RESP" = "Y" ];then
        cat << EOF
Поднимая тряпки с пола, вы находите солёную рыбу —
вероятно, из запасов бывшего владельца этих тряпок.
Добавьте эти предметы в инвентарь:

export I=$(IFS=, ; echo "${ITEMS[*]}"),\$I

Помните, вы можете проверить инвентарь:

echo \$I

EOF
    fi
else
    echo "Тряпки уже забраны"
fi
