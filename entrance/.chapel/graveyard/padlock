#!/usr/bin/env bash
# Если вы это читаете, значит вы вышли за пределы игры
# и читаете код, который управляет игрой.
#
#                    Поздравляем!
#
# Изучение Linux — это прежде всего любопытство, так что
# читайте этот код и попробуйте понять, что он делает.
#
# Когда будете готовы продолжить игру, возвращайтесь
# к свиткам. Если застряли — создайте issue на Gitlab.
# Мы с радостью дадим подсказку.
#

cat << EOF
На старом замке три диска, каждый украшен особым
символом:
  амулет
  корона
  надгробие с инициалами Ф.К.

Диски стёрты и поцарапаны, их цифры едва видны под
слоями ржавчины и грязи. Замысловатые символы, хоть и
выцветшие, намекают на связь замка с древними, загадочными
знаниями.

EOF
printf "Вы нашли числа? y/n  "

read RESP

if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then

cat << EOF

Старый осыпающийся мавзолей стоит молчаливый и грозный, его
обветренный каменный фасад увит плющом, а витражные окна разбиты.
Тяжёлый ржавый замок на большой, искусно вырезанной деревянной
двери тускло мерцает в слабом свете, пока вы готовитесь войти —
собранные древние числа готовы раскрыть тайны внутри.

EOF

    if grep  --quiet --only-matching '2712' <<< $I && \
       grep  --quiet --only-matching '1765' <<< $I && \
       grep  --quiet --only-matching '7432' <<< $I; then

        cat << EOF
Замок падает на землю с грохотом, и дверь мавзолея со скрипом
открывается, являя тускло освещённый интерьер, укутанный пылью
и паутиной.

EOF
        mv .mausoleum mausoleum
    else
        cat << EOF
Одно или несколько чисел неверны или отсутствуют в вашем инвентаре.
Помните, вы можете проверить инвентарь командой:

echo \$I

EOF

    fi

else
    cat << EOF
Продолжайте поиски чисел на кладбище.

EOF

fi




































































































































































































































































































































































































































































































































































































