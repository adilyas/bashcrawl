#!/usr/bin/env bash
# Если вы это читаете, значит вы вышли за пределы игры
# и читаете код, который управляет игрой.
#
#                    Поздравляем!
#
# Изучение Linux — это прежде всего любопытство, так что
# читайте этот код и попробуйте понять, что он делает.
#
# Когда будете готовы продолжить игру, возвращайтесь
# к свиткам. Если застряли — создайте issue на Gitlab.
# Мы с радостью дадим подсказку.
#

#import global functions from toplevel directory
FUNCTIONS=$(pwd)
FUNCTIONS=${FUNCTIONS%entrance*}entrance/.functions
. $FUNCTIONS

# this runs after the statue has been "destroyed"
# and this file has been renamed to 'pieces'
if [ "$0" = "./king" ]; then
    cat << EOF
Вы уже раскрыли тайное число.

Запомните его, добавив в инвентарь:

export I=7432,\$I
EOF
    exit 1
fi

# start the statue encounter
cat << EOF
Стоя перед статуями, вы размышляете о символах
на замке. Есть ли у вас в инвентаре предмет, который выглядит знакомо?

EOF
printf "У вас есть этот предмет? y/n  "

read RESP

if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
    if grep  --quiet --only-matching crown <<< $I; then
        cat << EOF

Вы держите корону в руках, размышляя, куда её поместить.

EOF
        printf "Введите номер статуи, на которую хотите надеть корону:  "

        read RESP

        if [ "${RESP:0:1}" -eq "5" -o "${RESP:0:2}" -eq "05" ]; then
            cat << EOF

Вы подходите к одинокой могиле с величественной статуей короля,
чья некогда величавая фигура теперь потрёпана и изношена. Корона,
когда-то украшавшая его голову, отсутствует. Лозы обвивают
основание статуи, оплетая ноги короля.

Когда вы бережно надеваете корону на голову статуи, глухой гул
разносится по земле, и каменные глаза короля медленно открываются,
сияя неземным светом. Статуя сдвигается, поднимая руку,
чтобы открыть скрытую гравировку на основании — тайное число **7432**,
начертанное древним письмом. Оно слабо пульсирует золотом, и король
торжественно кивает вам, прежде чем вернуться к неподвижности.

Уберите корону из инвентаря:

export I=\$(sed 's/crown,//' <<< \$I)

Запомните число, добавив его в инвентарь:

export I=7432,\$I

EOF
            mv statues king
        else
            cat << EOF

Потрёпанное надгробие обрамлено увитыми плющом колоннами, а
величественная мраморная статуя возвышается на нём. Статуя изображает
спокойную фигуру в королевском одеянии с наклонённой короной,
торжественно глядящую вдаль. Вокруг основания разбитые фонари
и потрескавшиеся урны напоминают о былом великолепии —
их тишину нарушают лишь шорох листьев и далёкие
крики ворона.

Когда вы поправляете корону на голове статуи, она соскальзывает
со своего ненадёжного места и падает на землю с грохотом.
В тот же миг тёмное мерцание магии вырывается из статуи,
окутывая вас пронизывающим холодом.

EOF
            let HP=HP-5
            export HP
            if [ "$HP" -le 0 ]; then
                cat << EOF
Волна тревоги накрывает вас, и тяжесть оседает в груди.
Вы убиты магией.

EOF
                gameover
                exit 1
            else
                cat << EOF
Магия оставляет вас дезориентированным и встревоженным, словно
тени прошлого на мгновение затуманили ваш разум и истощили силы.

Вычтите 5 из переменной HP:

let "HP=HP-5"

EOF
            fi

        fi
    else
        echo "У вас его нет! Продолжайте поиски."
        echo
        exit
    fi

else
    cat << EOF
Вы отступаете от статуй, продолжая поиск предмета.
EOF

fi




































































































































































































































































































































































































































































































































































































