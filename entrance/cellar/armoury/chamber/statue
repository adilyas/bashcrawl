#!/usr/bin/env bash
#
# Если вы это читаете, значит вы вышли за пределы игры
# и читаете код, который управляет игрой.
#
#                    Поздравляем!
#
# Изучение Linux — это прежде всего любопытство, так что
# читайте этот код и попробуйте понять, что он делает.
#
# Когда будете готовы продолжить игру, возвращайтесь
# к свиткам. Если застряли — создайте issue на Gitlab.
# Мы с радостью дадим подсказку.
#

# импортируем глобальные функции из корневой директории
FUNCTIONS=$(pwd)
FUNCTIONS=${FUNCTIONS%entrance*}entrance/.functions
. $FUNCTIONS

# это выполняется после того, как статуя была «уничтожена»
# и этот файл был переименован в 'pieces'
if [ "$0" = "./pieces" ]; then
    cat << EOF
Вы перебираете обломки разбитой статуи.

Вы не находите ничего интересного в останках статуи.

EOF
    exit 1
fi

# начинаем встречу со статуей
cat << EOF
Грубая статуя стоит в углу комнаты.

EOF
printf "Подойти к ней? y/n  "

read RESP

if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
    cat << EOF
Статуя оживает и грохочет:

КТО ПОСМЕЛ ВТОРГНУТЬСЯ В ПАЛАТУ ДУХОВ?

Она бьёт вас кулаком, нанося 5 единиц урона.

EOF

    # это не меняет HP пользователя,
    # а только вычисляет его после урона
    let "HP=HP-5"
    if [ "$HP" -le 0 ]; then
        cat << EOF
Статуя убила вас.

КОНЕЦ ИГРЫ!

EOF
        gameover
        exit 1
    fi

    perl -pe 's/coins/diamonds/' -i ./treasure
    printf "У вас есть меч? y/n  "
    read RESP
    if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
       if grep  --quiet --only-matching 'sword' <<< $I; then
           cat <<EOF
Вы ударяете статую, и она разбивается на куски!

Однако вы получили урон.
Вычтите 5 из переменной HP:

let "HP=HP-5"

EOF
           mv statue pieces
       else
           cat << EOF
Нет, у вас его нет! Бегите!
Вы получили урон от ожившей статуи.
Вычтите 5 из переменной HP:

let "HP=HP-5"

EOF
           rm treasure
           rm spell
      fi
    else
        cat <<EOF
Бегите!
Вы получили урон от ожившей статуи.
Вычтите 5 из переменной HP:

let "HP=HP-5"

EOF
   fi
else
    cat << EOF
Вы осторожно обходите статую, вспоминая рассказы о живых
камнях, подстерегающих путников в глубинах проклятых катакомб.

EOF

fi













































































































































































































































































































