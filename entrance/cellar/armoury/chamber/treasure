echo
if ! grep  --quiet --only-matching coins <<< $I; then
    cat << EOF
Вы нашли тайник с **монетами**! Они старые и потёртые
от времени, но всё ещё блестят в магическом свете,
исходящем из ваших глаз.

Добавьте этот предмет в инвентарь:

export I=coins,\$I

Помните, вы можете проверить инвентарь:

echo \$I

EOF
else
    echo "Это сокровище уже забрано."
    echo
fi








































































































































































































































































































































