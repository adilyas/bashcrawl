#!/usr/bin/env bash
#
# Если вы это читаете, значит вы вышли за пределы игры
# и читаете код, который управляет игрой.
#
#                    Поздравляем!
#
# Изучение Linux — это прежде всего любопытство, так что
# читайте этот код и попробуйте понять, что он делает.
#
# Когда будете готовы продолжить игру, возвращайтесь
# к свиткам. Если застряли — создайте issue на Gitlab.
# Мы с радостью дадим подсказку.
#

if ! [ -L portal ]; then
    cat << EOF
На западной стене высечены руны — язык древних мистиков,
некогда правивших этой землёй.

EOF
    printf "Хотите их прочитать? y/n  "
    read RESP

    if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
        cat << EOF
Вы вспоминаете уроки Кейтлин Зелёной, которая научила вас
этим древним письменам.

Руны содержат инструкцию, как вызвать портал, который
позволит вам пройти через невидимую дверь, скрытую
в стене.

В Bash символическая ссылка (symlink) — это *ярлык* на
другой файл или директорию. Создайте её из этой комнаты
в соседнюю:

ln -fs ../../../chapel/courtyard/aviary/hall portal

EOF
    else
        cat << EOF
Вы решаете, что магические надписи лучше
оставить как есть.

EOF
    fi
else
    cat << EOF
Вызванный портал всё ещё здесь, широко открытый, каким он был
с момента своего появления.

Вы можете пройти через него, как через любую другую дверь:

cd portal

EOF
fi


























































































































































































































































































































