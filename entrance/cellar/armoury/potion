# проверяем, находили ли мы уже эту бутылку ...
if [ -n "${HP+x}" ] ; then
  cat <<EOF
Вы уже проверяли эту бутылку.
EOF
else
# давайте исследуем бутылку...
cat << EOF
Вы нашли бутылку с зельем, в которой клубится
зелёная жидкость. Хотите её выпить?  y/n

EOF
read RESP

if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
   cat << EOF
Вкус терпкого зелёного растения наполняет ваш рот. Оно
согревает и укрепляет вас.

Создайте переменную для очков здоровья (HP). У вас
15HP:

export HP=15

EOF
else
    cat << EOF
Вы не вчера родились. Это зелье, вероятно,
отрава.

Создайте переменную для очков здоровья (HP). У вас
10HP:

export HP=10

EOF

fi

cat << EOF
Вы можете проверить здоровье в любое время:

echo \$HP

EOF
mv ../../.chapel ../../chapel 2>/dev/null
mv ../../.vault ../../vault 2>/dev/null
mv ../../.scrap ../../scrap 2>/dev/null
fi



















































































































































































































































































