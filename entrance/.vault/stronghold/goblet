#!/usr/bin/env bash
#
#
# Если вы это читаете, значит вы вышли за пределы игры
# и читаете код, который управляет игрой.
#
#                    Поздравляем!
#
# Изучение Linux — это прежде всего любопытство, так что
# читайте этот код и попробуйте понять, что он делает.
#
# Когда будете готовы продолжить игру, возвращайтесь
# к свиткам. Если застряли — создайте issue на Gitlab.
# Мы с радостью дадим подсказку.
#
if [[ -e orb1 && -e orb2 && -e orb3 ]]; then
    cat << EOF
Вы освободили материальную форму кубка. Добавьте 'goblet'
в свой инвентарь.

EOF
    exit
else
    cat << EOF
Вы пытаетесь схватить тускло светящийся кубок, но он
проходит сквозь ваши пальцы.

EOF

fi

printf "Вы застряли? Нужна подсказка? y/n  "
read RESP

if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
    cat << EOF
Попробуйте поискать на opensource.com подсказки о том,
как копировать файлы.

EOF
    printf "Всё ещё застряли? Нужен ответ? y/n  "
    read RESP

    if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
        cat << EOF
Команда cp копирует один файл в другой. Выполните
эти команды:

cp orb1 orb2
cp orb1 orb3

А затем запустите этот скрипт кубка снова для подтверждения.

EOF
    fi
fi



















































































































































































































































































