#!/usr/bin/env bash
#
# Если вы это читаете, значит вы вышли за пределы игры
# и читаете код, который управляет игрой.
#
#                    Поздравляем!
#
# Изучение Linux — это прежде всего любопытство, так что
# читайте этот код и попробуйте понять, что он делает.
#
# Когда будете готовы продолжить игру, возвращайтесь
# к свиткам. Если застряли — создайте issue на Gitlab.
# Мы с радостью дадим подсказку.
#

ITEM=crystal

if ! [ -f .bless ] ; then
    printf "У вас есть ледяной кристалл? y/n  "
    read RESP

    if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
        if grep  --quiet --only-matching "$ITEM" <<< "$I" ; then
            cat << EOF
Вы помещаете ледяной кристалл среди осколков стекла.
Меч в ваших руках становится холодным. Вы чувствуете
силу 1000 метелей, проходящую сквозь него.

Не забудьте убрать кристалл из инвентаря. Попробуйте
следующую команду:

export I=\$(sed 's/$ITEM,//' <<< \$I)
EOF
            touch .bless
            exit 0
        else
            cat << EOF
Вы ищете в инвентаре, но не находите ничего
похожего на кристалл

EOF
        fi
    fi
    cat << EOF
Вы чувствуете, что осколки стекла что-то ищут.
Что бы это ни было, сейчас вы не можете это дать.

Ступайте осторожно.

EOF
else
    cat << EOF
Вы уже поместили ледяной кристалл среди осколков стекла

EOF
fi



















































































































































































































































































