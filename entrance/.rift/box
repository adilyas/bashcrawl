#!/usr/bin/env bash
#
# Если вы это читаете, значит вы вышли за пределы игры
# и читаете код, который управляет игрой.
#
#                    Поздравляем!
#
# Изучение Linux — это прежде всего любопытство, так что
# читайте этот код и попробуйте понять, что он делает.
#
# Когда будете готовы продолжить игру, возвращайтесь
# к свиткам. Если застряли — создайте issue на Gitlab.
# Мы с радостью дадим подсказку.
#
cat << EOF
На земле стоит металлический ящик. Кажется, что он
светится изнутри. В ящике есть окошко. Окошко чёрное,
но на нём видна светящаяся надпись.

EOF
printf "Хотите прочитать надпись? y/n  "
read RESP

if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
    cat << EOF

.--------------------------------,
|       Welcome to POSIX         |
|   Enter your username:         |
'--------------------------------'
EOF
   read RESP

   if [ "$RESP" = "$USER" ]; then
       cat << EOF > armour
#!/usr/bin/env bash
cat << eof
Добро пожаловать, ${USER}, в вашу систему POSIX. Вы многому
научились, и теперь у вас есть базовые знания, чтобы стать
по-настоящему могущественным волшебником.

Вы нашли магические доспехи. Добавьте их в инвентарь.

eof
touch .armour
touch .bless

EOF
        chmod +x armour
        echo "Вы чувствуете магию в воздухе."
   fi
else
    cat << EOF
Ящик полон тайн, и часто лучше не вглядываться
слишком глубоко в загадки.

EOF
fi



















































































































































































































































































