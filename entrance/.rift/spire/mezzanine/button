cat << EOF
Вы видите светящуюся красную кнопку со стрелкой вверх,
выгравированной на её поверхности.

EOF
printf "Вам хочется нажать на кнопку?  y/n  "
read RESP

if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
    echo "Двери раздвигаются, открывая небольшую камеру."
    echo "UP" > .elevator/.direction
    ln -sf .elevator door &> /dev/null && \
        sleep 10 && \
        echo "Двери закрываются." && \
        unlink door &
    echo
fi
