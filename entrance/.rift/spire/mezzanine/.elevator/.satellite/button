cat << EOF
Вы видите светящуюся красную кнопку, на которой,
похоже, выгравирована стрелка вниз.

EOF
printf "Вас тянет нажать на кнопку?  y/n  "
read RESP

if [ "$RESP" = "y" -o "$RESP" = "Y" ]; then
    echo "Двери раздвигаются, открывая небольшую камеру."
    echo "DOWN" > ../.direction
    ln -sf .. door &> /dev/null && \
        sleep 10 && \
        echo "Двери закрываются." && \
        unlink door &
    echo
fi
