floors=666
countdown () {
	var=${floors}
	len=${#var}
	echo -n $var
    let m=var-1
	for t in `seq ${m} -1 1`
	do
		sleep 0.1
		for i in `seq ${len} -1 1`
		do
			echo -ne '\b'
		done
		if [ $len -gt ${#t} ]
		then
            let l=len-1
			for n in `seq ${l} -1 ${#t}`
			do
				echo -n '0'
			done
		fi
		echo -n $t
	done
}


countup () {
	var=${floors}
	for t in `seq 1 ${var}`
	do
		sleep 0.1
        len=${#t}
		for i in `seq 1 ${#var}`
		do
			echo -ne '\b'
		done
        if [ ${len} -lt ${#var} ]; then
            let n=${#var}-len
            for j in `seq 1 ${n}`
            do
                echo -ne '0'
            done
        fi
        echo -n $t
	done
}

if grep --quiet UP .direction; then
    cat << EOF
Вы слышите лёгкое жужжание и чувствуете тяжесть
в ногах, с неясным, тревожным ощущением движения.

Магический дисплей показывает:

EOF
    countup
    cat << EOF

Двери раздвигаются, а за ними — лишь тьма.

EOF
    echo "DOWN" > .direction
    ln -sf .satellite door && \
        sleep 10 && \
        echo "Двери закрываются." && \
        rm door &> /dev/null && \
    echo "DOWN" > .direction &
    echo
else
    cat << EOF
Вы слышите лёгкое жужжание и чувствуете лёгкость
в ногах, с неясным, тревожным ощущением движения.

Магический дисплей показывает:

EOF
    countdown
    echo
    echo
    echo "UP" > .direction &
    cat << EOF
Двери раздвигаются, а за ними — лишь тьма.

EOF
    ln -sf .. door && \
        sleep 10 && \
        echo "Двери закрываются." && \
        rm door &> /dev/null &
    echo
fi
